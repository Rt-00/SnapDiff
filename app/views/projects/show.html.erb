<% content_for :title, "#{@project.name} — SnapDiff" %>

<%# Breadcrumb %>
<nav class="text-sm mb-5" style="color: #a89984;">
  <%= link_to "Projects", projects_path, style: "color: #83a598;" %> /
  <span style="color: #ebdbb2;"><%= @project.name %></span>
</nav>

<div class="flex items-start justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold" style="color: #ebdbb2;"><%= @project.name %></h1>
    <% if @project.description.present? %>
      <p class="text-sm mt-1" style="color: #a89984;"><%= @project.description %></p>
    <% end %>
  </div>
  <div class="flex gap-2">
    <%= link_to "Edit", edit_project_path(@project),
          class: "px-3 py-1.5 rounded text-sm font-medium",
          style: "background-color: #3c3836; color: #ebdbb2; border: 1px solid #504945;" %>
    <%= link_to "Add endpoint", new_project_endpoint_path(@project),
          class: "px-3 py-1.5 rounded text-sm font-medium",
          style: "background-color: #fe8019; color: #282828;" %>
  </div>
</div>

<%# Endpoints table %>
<div class="rounded-lg overflow-hidden" style="border: 1px solid #504945;">
  <div class="px-4 py-3 flex items-center justify-between" style="background-color: #3c3836; border-bottom: 1px solid #504945;">
    <h2 class="font-semibold text-sm" style="color: #ebdbb2;">
      Endpoints <span class="ml-1 text-xs font-normal" style="color: #a89984;">(<%= @endpoints.count %>)</span>
    </h2>
  </div>

  <% if @endpoints.empty? %>
    <div class="text-center py-12" style="background-color: #32302f;">
      <p class="text-sm mb-3" style="color: #a89984;">No endpoints yet</p>
      <%= link_to "Add first endpoint", new_project_endpoint_path(@project),
            class: "text-sm",
            style: "color: #83a598;" %>
    </div>
  <% else %>
    <table class="w-full text-sm" style="background-color: #32302f;">
      <thead>
        <tr style="border-bottom: 1px solid #504945;">
          <th class="text-left px-4 py-2 font-medium" style="color: #a89984;">Name</th>
          <th class="text-left px-4 py-2 font-medium hidden sm:table-cell" style="color: #a89984;">URL</th>
          <th class="text-left px-4 py-2 font-medium hidden md:table-cell" style="color: #a89984;">Method</th>
          <th class="text-left px-4 py-2 font-medium hidden lg:table-cell" style="color: #a89984;">Schedule</th>
          <th class="px-4 py-2"></th>
        </tr>
      </thead>
      <tbody>
        <% @endpoints.each do |endpoint| %>
          <tr style="border-bottom: 1px solid #3c3836;">
            <td class="px-4 py-3">
              <%= link_to endpoint.name, project_endpoint_path(@project, endpoint),
                    style: "color: #83a598;" %>
            </td>
            <td class="px-4 py-3 hidden sm:table-cell" style="color: #a89984;">
              <span class="truncate max-w-xs block" title="<%= endpoint.url %>">
                <%= truncate(endpoint.url, length: 50) %>
              </span>
            </td>
            <td class="px-4 py-3 hidden md:table-cell">
              <span class="px-2 py-0.5 rounded text-xs font-mono"
                    style="background-color: #3c3836; color: <%= endpoint.http_method == 'GET' ? '#b8bb26' : '#fe8019' %>;">
                <%= endpoint.http_method %>
              </span>
            </td>
            <td class="px-4 py-3 hidden lg:table-cell" style="color: #a89984;">
              <%= endpoint.schedule.present? ? endpoint.schedule : "—" %>
            </td>
            <td class="px-4 py-3 text-right">
              <%= link_to "View", project_endpoint_path(@project, endpoint),
                    class: "text-xs px-2 py-1 rounded",
                    style: "color: #a89984; background-color: #3c3836;" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>
