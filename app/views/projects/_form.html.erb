<%= form_with model: project, class: "space-y-4" do |f| %>
  <%= render "shared/form_errors", resource: project %>

  <div>
    <%= f.label :name, class: "block text-sm font-medium mb-1", style: "color: #d5c4a1;" %>
    <%= f.text_field :name, placeholder: "My API Project",
          class: "w-full px-3 py-2 rounded text-sm",
          style: "background-color: #282828; border: 1px solid #504945; color: #ebdbb2; outline: none;" %>
  </div>

  <div>
    <%= f.label :description, class: "block text-sm font-medium mb-1", style: "color: #d5c4a1;" %>
    <%= f.text_area :description, rows: 3, placeholder: "Optional description of what this project monitors",
          class: "w-full px-3 py-2 rounded text-sm",
          style: "background-color: #282828; border: 1px solid #504945; color: #ebdbb2; outline: none; resize: vertical;" %>
  </div>

  <div class="flex gap-3 pt-1">
    <%= f.submit class: "px-4 py-2 rounded font-medium text-sm cursor-pointer",
          style: "background-color: #fe8019; color: #282828;" %>
    <%= link_to "Cancel", project.persisted? ? project : projects_path,
          class: "px-4 py-2 rounded font-medium text-sm",
          style: "background-color: #3c3836; color: #a89984; border: 1px solid #504945;" %>
  </div>
<% end %>
