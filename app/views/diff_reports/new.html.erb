<% content_for :title, "Compare Snapshots — SnapDiff" %>

<div class="max-w-xl">
  <h1 class="text-2xl font-bold mb-6" style="color: #ebdbb2;">Compare snapshots</h1>

  <%= form_with url: diff_reports_path, method: :post, class: "space-y-5" do |f| %>
    <div class="rounded-lg p-5" style="background-color: #3c3836; border: 1px solid #504945;">
      <h2 class="font-semibold mb-3 text-sm" style="color: #a89984;">SNAPSHOT A (before)</h2>
      <div>
        <%= label_tag :snapshot_a_id, "Snapshot ID", class: "block text-sm font-medium mb-1", style: "color: #d5c4a1;" %>
        <%= number_field_tag :snapshot_a_id, @snapshot_a_id,
              min: 1,
              placeholder: "e.g. 42",
              class: "w-full px-3 py-2 rounded text-sm font-mono",
              style: "background-color: #282828; border: 1px solid #504945; color: #ebdbb2; outline: none;" %>
      </div>
    </div>

    <div class="text-center text-2xl" style="color: #a89984;">↕</div>

    <div class="rounded-lg p-5" style="background-color: #3c3836; border: 1px solid #504945;">
      <h2 class="font-semibold mb-3 text-sm" style="color: #a89984;">SNAPSHOT B (after)</h2>
      <div>
        <%= label_tag :snapshot_b_id, "Snapshot ID", class: "block text-sm font-medium mb-1", style: "color: #d5c4a1;" %>
        <%= number_field_tag :snapshot_b_id,
              nil,
              min: 1,
              placeholder: "e.g. 43",
              class: "w-full px-3 py-2 rounded text-sm font-mono",
              style: "background-color: #282828; border: 1px solid #504945; color: #ebdbb2; outline: none;" %>
      </div>
    </div>

    <%= submit_tag "Compare",
          class: "w-full py-2 px-4 rounded font-medium text-sm cursor-pointer",
          style: "background-color: #fe8019; color: #282828;" %>
  <% end %>
</div>
