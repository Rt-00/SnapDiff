<% content_for :title, "Sign In — SnapDiff" %>

<h2 class="text-xl font-semibold mb-5" style="color: #ebdbb2;">Sign in</h2>

<%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div class="mb-4">
    <%= f.label :email, class: "block text-sm font-medium mb-1", style: "color: #d5c4a1;" %>
    <%= f.email_field :email, autofocus: true, autocomplete: "email",
          class: "w-full px-3 py-2 rounded text-sm",
          style: "background-color: #282828; border: 1px solid #504945; color: #ebdbb2; outline: none;" %>
  </div>

  <div class="mb-5">
    <%= f.label :password, class: "block text-sm font-medium mb-1", style: "color: #d5c4a1;" %>
    <%= f.password_field :password, autocomplete: "current-password",
          class: "w-full px-3 py-2 rounded text-sm",
          style: "background-color: #282828; border: 1px solid #504945; color: #ebdbb2; outline: none;" %>
  </div>

  <% if devise_mapping.rememberable? %>
    <div class="mb-4 flex items-center gap-2">
      <%= f.check_box :remember_me, style: "accent-color: #fe8019;" %>
      <%= f.label :remember_me, class: "text-sm", style: "color: #a89984;" %>
    </div>
  <% end %>

  <div>
    <%= f.submit "Sign in",
          class: "w-full py-2 px-4 rounded font-medium text-sm cursor-pointer transition-opacity hover:opacity-90",
          style: "background-color: #fe8019; color: #282828;" %>
  </div>
<% end %>

<%= render "devise/shared/links" %>
