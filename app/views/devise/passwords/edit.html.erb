<% content_for :title, "Change Password — SnapDiff" %>

<h2 class="text-xl font-semibold mb-5" style="color: #ebdbb2;">Change your password</h2>

<%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>
  <%= f.hidden_field :reset_password_token %>

  <div class="mb-4">
    <%= f.label :password, "New password", class: "block text-sm font-medium mb-1", style: "color: #d5c4a1;" %>
    <% if @minimum_password_length %>
      <p class="text-xs mb-1" style="color: #a89984;"><%= @minimum_password_length %> characters minimum</p>
    <% end %>
    <%= f.password_field :password, autofocus: true, autocomplete: "new-password",
          class: "w-full px-3 py-2 rounded text-sm",
          style: "background-color: #282828; border: 1px solid #504945; color: #ebdbb2; outline: none;" %>
  </div>

  <div class="mb-5">
    <%= f.label :password_confirmation, "Confirm new password", class: "block text-sm font-medium mb-1", style: "color: #d5c4a1;" %>
    <%= f.password_field :password_confirmation, autocomplete: "new-password",
          class: "w-full px-3 py-2 rounded text-sm",
          style: "background-color: #282828; border: 1px solid #504945; color: #ebdbb2; outline: none;" %>
  </div>

  <div>
    <%= f.submit "Change password",
          class: "w-full py-2 px-4 rounded font-medium text-sm cursor-pointer",
          style: "background-color: #fe8019; color: #282828;" %>
  </div>
<% end %>

<%= render "devise/shared/links" %>
