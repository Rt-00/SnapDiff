<% content_for :title, "Forgot Password — SnapDiff" %>

<h2 class="text-xl font-semibold mb-5" style="color: #ebdbb2;">Forgot your password?</h2>

<%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div class="mb-5">
    <%= f.label :email, class: "block text-sm font-medium mb-1", style: "color: #d5c4a1;" %>
    <%= f.email_field :email, autofocus: true, autocomplete: "email",
          class: "w-full px-3 py-2 rounded text-sm",
          style: "background-color: #282828; border: 1px solid #504945; color: #ebdbb2; outline: none;" %>
  </div>

  <div>
    <%= f.submit "Send reset instructions",
          class: "w-full py-2 px-4 rounded font-medium text-sm cursor-pointer",
          style: "background-color: #fe8019; color: #282828;" %>
  </div>
<% end %>

<%= render "devise/shared/links" %>
