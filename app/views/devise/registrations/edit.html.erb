<% content_for :title, "Account Settings — SnapDiff" %>

<div class="max-w-lg">
  <h2 class="text-xl font-semibold mb-6" style="color: #ebdbb2;">Account settings</h2>

  <div class="rounded-lg p-6 mb-6" style="background-color: #3c3836; border: 1px solid #504945;">
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="mb-4">
        <%= f.label :email, class: "block text-sm font-medium mb-1", style: "color: #d5c4a1;" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "w-full px-3 py-2 rounded text-sm",
              style: "background-color: #282828; border: 1px solid #504945; color: #ebdbb2; outline: none;" %>
        <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
          <p class="mt-1 text-xs" style="color: #fabd2f;">Waiting confirmation for: <%= resource.unconfirmed_email %></p>
        <% end %>
      </div>

      <div class="mb-4">
        <%= f.label :password, "New password (leave blank to keep current)", class: "block text-sm font-medium mb-1", style: "color: #d5c4a1;" %>
        <% if @minimum_password_length %>
          <p class="text-xs mb-1" style="color: #a89984;"><%= @minimum_password_length %> characters minimum</p>
        <% end %>
        <%= f.password_field :password, autocomplete: "new-password",
              class: "w-full px-3 py-2 rounded text-sm",
              style: "background-color: #282828; border: 1px solid #504945; color: #ebdbb2; outline: none;" %>
      </div>

      <div class="mb-4">
        <%= f.label :password_confirmation, class: "block text-sm font-medium mb-1", style: "color: #d5c4a1;" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password",
              class: "w-full px-3 py-2 rounded text-sm",
              style: "background-color: #282828; border: 1px solid #504945; color: #ebdbb2; outline: none;" %>
      </div>

      <div class="mb-5">
        <%= f.label :current_password, "Current password (required to save changes)", class: "block text-sm font-medium mb-1", style: "color: #d5c4a1;" %>
        <%= f.password_field :current_password, autocomplete: "current-password",
              class: "w-full px-3 py-2 rounded text-sm",
              style: "background-color: #282828; border: 1px solid #504945; color: #ebdbb2; outline: none;" %>
      </div>

      <div>
        <%= f.submit "Update account",
              class: "py-2 px-4 rounded font-medium text-sm cursor-pointer",
              style: "background-color: #fe8019; color: #282828;" %>
      </div>
    <% end %>
  </div>

  <div class="rounded-lg p-4" style="background-color: #3c3836; border: 1px solid #504945;">
    <h3 class="text-sm font-semibold mb-2" style="color: #fb4934;">Danger zone</h3>
    <p class="text-sm mb-3" style="color: #a89984;">Once you delete your account, there is no going back.</p>
    <%= button_to "Delete my account", registration_path(resource_name),
          data: { turbo_confirm: "Are you sure? This cannot be undone." }, method: :delete,
          class: "py-1.5 px-3 rounded text-sm font-medium cursor-pointer",
          style: "background-color: #2a1e1e; border: 1px solid #fb4934; color: #fb4934;" %>
  </div>
</div>
